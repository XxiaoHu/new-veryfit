{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "feryfit/hero-banner",
	"version": "0.1.0",
	"title": "首页横幅",
	"category": "widgets",
	"icon": "cover-image",
	"description": "一个可以自定义背景图片、标题和副标题的首页横幅区块。",
	"example": {},
	"supports": {
		"html": false,
		"align": [
			"wide",
			"full"
		]
	},
	"textdomain": "feryfit",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"viewScript": "file:./view.js",
	"render": "file:./render.php",
	"attributes": {
		"backgroundImageId": {
			"type": "number",
			"default": 0
		},
		"backgroundImage": {
			"type": "string",
			"default": ""
		},
		"mobileBackgroundImageId": {
			"type": "number",
			"default": 0
		},
		"mobileBackgroundImage": {
			"type": "string",
			"default": ""
		},
		"title": {
			"type": "string",
			"default": "欢迎来到我们的网站"
		},
		"subtitle": {
			"type": "string",
			"default": "这是一个精美的首页横幅"
		},
		"keywords": {
			"type": "array",
			"default": [],
			"items": {
				"type": "string"
			}
		},
		"bannerWidth": {
			"type": "number",
			"default": 1940
		},
		"bannerHeight": {
			"type": "number",
			"default": 480
		},
		"searchPlaceholder": {
			"type": "string",
			"default": "Search by question or keyword"
		},
		"searchButtonText": {
			"type": "string",
			"default": "Search"
		}
	}
}