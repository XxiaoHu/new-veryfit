{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "feryfit/custom-banner",
  "version": "0.1.0",
  "title": "Contact us Banner",
  "category": "widgets",
  "icon": "cover-image",
  "description": "自定义 Banner 图片区块，支持分别配置 PC 和移动端背景图",
  "example": {},
  "supports": {
    "html": false,
    "align": [
      "wide",
      "full"
    ]
  },
  "textdomain": "feryfit",
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "style": "file:./style-index.css",
  "attributes": {
    "backgroundImageId": {
      "type": "number",
      "default": 0
    },
    "backgroundImage": {
      "type": "string",
      "default": ""
    },
    "mobileBackgroundImageId": {
      "type": "number",
      "default": 0
    },
    "mobileBackgroundImage": {
      "type": "string",
      "default": ""
    },
    "title": {
      "type": "string",
      "source": "html",
      "selector": ".custom-banner__title",
      "default": "Contact VeryFit Support"
    }
  }
}