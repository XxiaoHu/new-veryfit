{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "feryfit/video-grid",
  "version": "0.1.0",
  "title": "Video Grid",
  "category": "widgets",
  "icon": "video-alt",
  "description": "视频卡片网格区块，展示12个视频卡片，PC端4列3行，移动端2列",
  "example": {},
  "supports": {
    "html": false,
    "align": [
      "wide",
      "full"
    ]
  },
  "textdomain": "feryfit",
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "style": "file:./style-index.css",
  "render": "file:./render.php",
  "attributes": {
    "sectionTitle": {
      "type": "string",
      "default": "Video"
    }
  }
}